{
  "model": "sonnet[1m]",
  "effortLevel": "medium",
  "autoMemoryEnabled": false,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Agent",
      "AskUserQuestion",
      "Bash",
      "Edit",
      "EnterPlanMode",
      "EnterWorktree",
      "ExitPlanMode",
      "ExitWorktree",
      "Glob",
      "Grep",
      "PowerShell(*)",
      "Read",
      "Search",
      "Skill",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "ToolSearch",
      "WebFetch",
      "WebSearch",
      "Write"
    ]
  }
}
